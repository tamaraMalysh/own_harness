# LLM provider base URL (OpenAI-compatible endpoint)
# Ollama local: http://localhost:11434/v1
# OpenAI: https://api.openai.com/v1
LLM_BASE_URL=http://localhost:11434/v1

# API key (use "ollama" for local Ollama, your key for cloud providers)
LLM_API_KEY=ollama

# Model name as recognized by your provider
# Ollama examples: qwen3.6:latest, gemma4:latest
# OpenAI examples: gpt-4o, gpt-4o-mini
LLM_MODEL=qwen3.6:latest
